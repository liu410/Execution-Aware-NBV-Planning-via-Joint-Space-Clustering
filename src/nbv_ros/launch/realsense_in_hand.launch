<!--
  realsense_in_hand.launch

  Launch file for the Intel RealSense camera mounted on the robot end-effector
  (eye-in-hand configuration).

  This launch file starts the realsense2_camera driver and configures:
    - RGB stream
    - Depth stream
    - Depth-to-color alignment
    - Point cloud generation

  Additionally, it publishes static TF transforms between the robot wrist
  and the camera frames.

  Topics produced by realsense2_camera include:
    /in_hand_camera/color/image_raw
    /in_hand_camera/depth/image_rect_raw
    /in_hand_camera/aligned_depth_to_color/image_raw
    /in_hand_camera/depth/color/points
-->

<launch>

  <!-- Camera identification -->
  <arg name="camera_name" default="in_hand_camera"/>
  <arg name="serial_no" default="335122271346"/>

  <!-- Enable/disable streams -->
  <arg name="enable_color" default="true"/>
  <arg name="enable_depth" default="true"/>
  <arg name="enable_infra" default="false"/>
  <arg name="align_depth" default="true"/>
  <arg name="enable_pointcloud" default="true"/>
  <arg name="publish_tf" default="true"/>

  <!-- Resolution settings (0 = use JSON configuration) -->
  <arg name="color_width" default="640"/>
  <arg name="color_height" default="480"/>
  <arg name="color_fps" default="15"/>

  <arg name="depth_width" default="640"/>
  <arg name="depth_height" default="480"/>
  <arg name="depth_fps" default="30"/>

  <!-- ========================================================= -->
  <!-- RealSense driver node                                     -->
  <!-- ========================================================= -->

  <include file="$(find realsense2_camera)/launch/rs_camera.launch">

    <arg name="camera" value="$(arg camera_name)"/>
    <arg name="serial_no" value="$(arg serial_no)"/>
    <arg name="tf_prefix" value="$(arg camera_name)"/>

    <!-- Stream configuration -->
    <arg name="enable_color" value="$(arg enable_color)"/>
    <arg name="enable_depth" value="$(arg enable_depth)"/>
    <arg name="enable_infra1" value="$(arg enable_infra)"/>
    <arg name="enable_infra2" value="$(arg enable_infra)"/>

    <!-- Resolution and frame rate -->
    <arg name="color_width" value="$(arg color_width)"/>
    <arg name="color_height" value="$(arg color_height)"/>
    <arg name="color_fps" value="$(arg color_fps)"/>

    <arg name="depth_width" value="$(arg depth_width)"/>
    <arg name="depth_height" value="$(arg depth_height)"/>
    <arg name="depth_fps" value="$(arg depth_fps)"/>

    <!-- Depth alignment (depth -> color frame) -->
    <arg name="align_depth" value="$(arg align_depth)"/>

    <!-- Point cloud generation -->
    <arg name="enable_pointcloud" value="$(arg enable_pointcloud)"/>
    <arg name="pointcloud_texture_stream" value="RS2_STREAM_COLOR"/>
    <arg name="allow_no_texture_points" value="true"/>

    <!-- TF publication -->
    <arg name="publish_tf" value="$(arg publish_tf)"/>

  </include>

  <!-- ========================================================= -->
  <!-- Static TF transforms                                      -->
  <!-- ========================================================= -->

  <!-- Camera pose relative to the robot wrist -->
  <node pkg="tf"
        type="static_transform_publisher"
        name="in_hand_camera_tf_pub"
        args="0.0866025 0.055 0.05 0.61237 -0.35355 -0.35355 -0.61237
              wrist3_Link in_hand_camera_link 100"/>

  <!-- Frame alignment for point cloud processing -->
  <node pkg="tf"
        type="static_transform_publisher"
        name="in_hand_camera_tf_pointcloud"
        args="0 0 0 0 0 0 1
              in_hand_camera_aligned_depth_to_color_frame
              in_hand_camera_color_optical_frame
              0"/>

</launch>